# ── REQUIRED ─────────────────────────────────────────────────────────────────
# GitHub personal access token — github.com → Settings → Developer settings → Tokens
GITHUB_TOKEN=ghp_...

# Your GitHub username — used to check issue assignment before push
GITHUB_USERNAME=your-github-username

# Groq API key — console.groq.com (FREE tier)
# Used for: issue scoring (Llama 8B), planning (Llama 70B), reviewing (Qwen 32B),
#           test failure classification, workflow detection
GROQ_API_KEY=gsk_...

# ntfy.sh topic — your unique push notification channel
# Install the ntfy app on Android/iOS → Subscribe to this topic
NTFY_TOPIC=fi-pr-yourname
NTFY_URL=https://ntfy.sh

# Approval server URL — where ntfy action buttons POST to
# For local-only use: http://localhost:8080 (phone won't reach this without a tunnel)
# For phone approval: use ngrok / Cloudflare Tunnel / tailscale
#   ngrok:  ngrok http 8080  → set APPROVAL_SERVER_URL=https://xxxx.ngrok.io
#   cfTunnel: cloudflared tunnel --url http://localhost:8080
APPROVAL_SERVER_URL=http://localhost:8080

# ── PRIMARY CODER (RECOMMENDED — FREE) ───────────────────────────────────────
# Gemini 2.5 Pro — primary code generation model
# Get key at: aistudio.google.com → API Keys
GEMINI_API_KEY=AIza...

# ── FALLBACK CODERS (OPTIONAL — extend fallback chain) ───────────────────────
# OpenRouter — gives access to Qwen 2.5 Coder 72B and DeepSeek Coder V2
# openrouter.ai → Keys (has a free tier for some models)
OPENROUTER_API_KEY=sk-or-...

# Anthropic Claude — last-resort fallback only (paid)
# Use only if Gemini + Qwen + DeepSeek all fail
ANTHROPIC_API_KEY=sk-ant-...

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# ntfy auth token — only needed for private ntfy topics
# ntfy.sh → login → create token → set here
NTFY_TOKEN=tk_...

# Custom reply topic for ntfy (defaults to {NTFY_TOPIC}-reply)
# NTFY_REPLY_TOPIC=fi-pr-yourname-reply

# Approval server port (default 8080)
# APPROVAL_SERVER_PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
